# Root-level env example — copy each section into backend/.env and frontend/.env

# --- Backend ---
DB_URL=jdbc:postgresql://<supabase-host>:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-password
REDIS_URL=rediss://:<upstash-token>@<upstash-host>:6380
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_EXPIRATION_MS=86400000

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
